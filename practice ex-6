#include <stdio.h>

int main() {
    int pages[] = {1, 2, 3, 2, 4, 1, 5};
    int frames[3] = {-1, -1, -1};
    int i, j, k = 0, found, faults = 0;

    for (i = 0; i < 7; i++) {
        found = 0;

        for (j = 0; j < 3; j++)
            if (frames[j] == pages[i])
                found = 1;

        if (!found) {
            frames[k] = pages[i];
            k = (k + 1) % 3;   // FIFO replacement
            faults++;
        }

        printf("Page %d -> ", pages[i]);
        for (j = 0; j < 3; j++)
            printf("%d ", frames[j]);
        printf("\n");
    }

    printf("Total Page Faults = %d\n", faults);

    return 0;
}
