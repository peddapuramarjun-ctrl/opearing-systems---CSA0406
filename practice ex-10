#include <stdio.h>

int main() {
    int bt[10], wt[10], n, i;
    float avg = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    printf("Enter Burst Times:\n");
    for (i = 0; i < n; i++)
        scanf("%d", &bt[i]);

    wt[0] = 0;
    for (i = 1; i < n; i++)
        wt[i] = wt[i - 1] + bt[i - 1];

    for (i = 0; i < n; i++)
        avg += wt[i];

    printf("Average Waiting Time = %.2f\n", avg / n);

    return 0;
}
