#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>

int main() {
    int fd;
    char data[] = "Hello, File System!";
    char buffer[50];

    fd = open("sample.txt", O_CREAT | O_RDWR, 0644);

    write(fd, data, sizeof(data));

    lseek(fd, 0, SEEK_SET);

    read(fd, buffer, sizeof(data));

    printf("File Content: %s\n", buffer);

    close(fd);

    return 0;
}
