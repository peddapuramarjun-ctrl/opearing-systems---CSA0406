#include <stdio.h>
#include <pthread.h>
#include <unistd.h>

void *odd(void *arg) {
    for (int i = 1; i <= 9; i += 2) {
        printf("Odd: %d\n", i);
        sleep(1);
    }
    return NULL;
}

void *even(void *arg) {
    for (int i = 2; i <= 10; i += 2) {
        printf("Even: %d\n", i);
        sleep(1);
    }
    return NULL;
}

int main() {
    pthread_t t1, t2;

    pthread_create(&t1, NULL, odd, NULL);
    pthread_create(&t2, NULL, even, NULL);

    pthread_join(t1, NULL);
    pthread_join(t2, NULL);

    return 0;
}
