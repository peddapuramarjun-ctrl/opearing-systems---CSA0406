#include <stdio.h>

int main() {
    int block[] = {100, 500, 200, 300, 600};
    int process[] = {212, 417, 112, 426};
    int allocation[4];
    int i, j;

    for (i = 0; i < 4; i++)
        allocation[i] = -1;

    for (i = 0; i < 4; i++) {
        for (j = 0; j < 5; j++) {
            if (block[j] >= process[i]) {
                allocation[i] = j;
                block[j] -= process[i];
                break;
            }
        }
    }

    printf("Process\tBlock\n");
    for (i = 0; i < 4; i++) {
        if (allocation[i] != -1)
            printf("%d\t%d\n", process[i], allocation[i] + 1);
        else
            printf("%d\tNot Allocated\n", process[i]);
    }

    return 0;
}
