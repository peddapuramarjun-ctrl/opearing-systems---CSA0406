#include <stdio.h>

#define MAX 10

int queue[MAX];
int front = -1, rear = -1;

// Insert a process into the ready queue
void enqueue(int process) {
    if (rear == MAX - 1) {
        printf("Ready Queue is Full!\n");
        return;
    }

    if (front == -1)
        front = 0;

    queue[++rear] = process;
    printf("Process P%d added to Ready Queue.\n", process);
}

// Remove a process from the ready queue
void dequeue() {
    if (front == -1 || front > rear) {
        printf("Ready Queue is Empty!\n");
        return;
    }

    printf("Process P%d is allocated CPU and removed from Ready Queue.\n", queue[front]);
    front++;

    if (front > rear)
        front = rear = -1;
}

// Display the ready queue
void display() {
    if (front == -1) {
        printf("Ready Queue is Empty!\n");
        return;
    }

    printf("Ready Queue: ");
    for (int i = front; i <= rear; i++) {
        printf("P%d ", queue[i]);
    }
    printf("\n");
}

int main() {
    int choice, process;

    while (1) {
        printf("\n--- Ready Queue Simulation ---\n");
        printf("1. Add Process\n");
        printf("2. Allocate CPU (Remove Process)\n");
        printf("3. Display Ready Queue\n");
        printf("4. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                printf("Enter Process ID: ");
                scanf("%d", &process);
                enqueue(process);
                break;

            case 2:
                dequeue();
                break;

            case 3:
                display();
                break;

            case 4:
                printf("Exiting...\n");
                return 0;

            default:
                printf("Invalid Choice!\n");
        }
    }

    return 0;
}
